#--------------------------------------------------------------------
# ENVIRONMENT (PROD)
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://viral.2gotas.com.br/'
app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE (Configure com os dados da VPS)
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = viral
database.default.username = usuario_do_banco
database.default.password = senha_do_banco
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = 'writable/session'

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# 4 = Loga apenas erros e warnings (ideal para producao)
logger.threshold = 4
